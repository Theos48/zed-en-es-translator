#!/usr/bin/env bash
set -euo pipefail

# Bergamot v0.6.0 promotes all warnings to errors. GCC 12 diagnoses the
# upstream intgemm AVX-512 intrinsic fallback as maybe-uninitialized even for
# the x86-64/SSE4.1 runtime dispatch build. Keep every other upstream warning
# policy intact and demote only that compiler diagnostic.
exec /usr/bin/c++ \
  -Wno-error=comment \
  -Wno-error=maybe-uninitialized \
  -Wno-error=unknown-pragmas \
  "$@"
