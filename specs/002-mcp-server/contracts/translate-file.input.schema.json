{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://theos48.github.io/zed-en-es-translator/schemas/mcp/translate-file.input.schema.json",
  "title": "TranslateFileToolInput",
  "type": "object",
  "additionalProperties": false,
  "required": ["workspace_root", "file_path"],
  "properties": {
    "workspace_root": {
      "type": "string",
      "minLength": 1,
      "description": "Authorized workspace root supplied by the client context."
    },
    "file_path": {
      "type": "string",
      "minLength": 1,
      "description": "Requested path inside the authorized workspace."
    },
    "source_language": {
      "type": "string",
      "const": "en",
      "default": "en"
    },
    "target_language": {
      "type": "string",
      "const": "es",
      "default": "es"
    },
    "tone": {
      "type": "string",
      "enum": ["technical_neutral"],
      "default": "technical_neutral"
    },
    "preserve_formatting": {
      "type": "boolean",
      "const": true,
      "default": true
    },
    "remote_confirmed": {
      "type": "boolean",
      "default": false,
      "description": "Request-scoped confirmation for explicitly configured non-local providers."
    }
  }
}
