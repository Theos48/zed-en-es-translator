{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/zed-en-es-translator/translate-result.schema.json",
  "title": "TranslateResult",
  "oneOf": [
    {
      "title": "TranslateSuccess",
      "type": "object",
      "additionalProperties": false,
      "required": ["translated_text"],
      "properties": {
        "translated_text": {
          "type": "string",
          "maxLength": 40960
        }
      }
    },
    {
      "title": "TranslateFailure",
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": {
          "enum": [
            "INVALID_INPUT",
            "UNSUPPORTED_LANGUAGE_PAIR",
            "UNSUPPORTED_FILE_TYPE",
            "FILE_TOO_LARGE",
            "FILE_NOT_FOUND",
            "PATH_NOT_ALLOWED",
            "NON_UTF8_INPUT",
            "NO_TRANSLATABLE_SEGMENTS",
            "SECRET_DETECTED",
            "PROVIDER_NOT_CONFIGURED",
            "REMOTE_CONFIRMATION_REQUIRED",
            "PROVIDER_FAILED",
            "PROVIDER_TIMEOUT",
            "INTERNAL_ERROR"
          ]
        },
        "message": {
          "type": "string",
          "maxLength": 512
        }
      }
    }
  ]
}
