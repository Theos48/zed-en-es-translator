# zed-en-es-translator
#
# Solo se excluyen secretos, estado local y artefactos reproducibles. Codigo,
# locks, documentacion, specs y assets del producto quedan visibles para
# revision y versionado.

###############################################################################
# Sistema operativo y editores
###############################################################################

.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~
*.orig
*.rej
*.bak
.vscode/
.idea/
*.code-workspace
.zed/

###############################################################################
# Secretos y estado privado
###############################################################################

.env
.env.*
!.env.example
!.env.sample
*.pem
*.key
*.crt
*.p12
*.pfx
id_rsa
id_ed25519
*.kubeconfig
secrets/
credentials/
provider-cache/

###############################################################################
# Estado local de herramientas
###############################################################################

.agents/
.codex/
.cache/
.local/
*.log
*.log.*
logs/
log/
tmp/
temp/
.tmp/

###############################################################################
# Builds y paquetes reproducibles
###############################################################################

target/
**/target/
native/translator-embedded-runtime/build/
marketplace-artifacts/
*.wasm
*.wasm.map
*.rlib
*.rmeta
*.profraw
*.profdata
flamegraph.svg
*.tar
*.tar.gz
*.tgz
*.zip

###############################################################################
# Modelos y bases de datos locales
###############################################################################

models/
model-cache/
*.sqlite
*.sqlite3
*.db

###############################################################################
# Temporales internos de Spec Kit
###############################################################################

.specify/**/.cache/
.specify/**/*.bak
.specify/**/*.tmp
